<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>YFex.Messaging.Rpc.Wolverine</RootNamespace>
    <AssemblyName>YFex.Messaging.Rpc.Wolverine</AssemblyName>
    <PackageId>YFex.Messaging.Rpc.Wolverine</PackageId>
