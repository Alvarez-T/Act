  <ItemGroup>
    <PackageReference Include="WolverineFx" Version="6.14.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\YFex.Messaging.Rpc\YFex.Messaging.Rpc.csproj" />
  </ItemGroup>

</Project>
