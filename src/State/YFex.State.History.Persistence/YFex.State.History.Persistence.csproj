<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsAotCompatible>true</IsAotCompatible>
    <PackageId>YFex.State.History.Persistence</PackageId>
    <Description>Snapshot provider for YFex.State.History undo/redo contexts. Captures and restores UndoContext stacks across process restarts using MemoryPack + System.Text.Json value serialization.</Description>
    <PackageTags>yfex;persistence;undo;history;snapshot</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MemoryPack" Version="1.21.4" />
    <PackageReference Include="System.Text.Json" Version="11.0.0-preview.5.26302.115" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Persistence\YFex.Persistence\YFex.Persistence.csproj" />
    <ProjectReference Include="..\YFex.State.History\YFex.State.History.csproj" />
  </ItemGroup>

</Project>
